#!/usr/bin/env bash
# distill — generate a self-contained install.sh for any CLI tool
# https://github.com/milvasic/distill

set -euo pipefail

VERSION="0.1.0"

# ── Colors & logging ──────────────────────────────────────────────────────────
RED="\033[0;31m"
GREEN="\033[0;32m"
BOLD="\033[1m"
RESET="\033[0m"

log() { printf "\n${BOLD}=== %s ===${RESET}\n" "$1" >&2; }
error() { printf "${RED}ERROR:${RESET} %s\n" "$1" >&2; }
ok() { printf "${GREEN}%s${RESET}\n" "$1" >&2; }

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
	cat >&2 <<EOF
distill v${VERSION} — generate a self-contained install.sh for any CLI tool.

Usage:
  distill [options]

Options:
  --name NAME          Binary name (required)
  --asset-url URL      Direct URL to the downloadable asset (required)
  --installer-url URL  URL to the generated install.sh (required)
  --install-dir DIR    Installation directory          (default: /usr/local/bin)
  --asset-type TYPE    Asset type: script | binary     (default: script)
  --version-url URL    Plain-text version endpoint     (required for binary)
  --output FILE        Write to FILE instead of stdout
  --version            Print version and exit
  --help, -h           Show this message

When called without flags in an interactive terminal, distill prompts for
each value.

Examples:
  # Interactive wizard
  distill

  # Non-interactive, output to stdout
  distill --name mytool \\
    --asset-url https://raw.githubusercontent.com/you/mytool/refs/heads/main/mytool \\
    --installer-url https://raw.githubusercontent.com/you/mytool/refs/heads/main/install.sh

  # Write directly to a file
  distill --name mytool ... --output install.sh
EOF
	exit 1
}

# ── Interactive prompt ─────────────────────────────────────────────────────────
# Usage: prompt VAR_NAME "Label" ["default_value"]
prompt() {
	local _var="$1" _label="$2" _default="${3:-}"
	local _value

	if [ -n "$_default" ]; then
		printf "${BOLD}%s${RESET} [%s]: " "$_label" "$_default" >&2
	else
		printf "${BOLD}%s${RESET}: " "$_label" >&2
	fi

	IFS= read -r _value
	_value="${_value:-$_default}"
	printf -v "$_var" '%s' "$_value"
}

# ── Generator ─────────────────────────────────────────────────────────────────
generate_install_sh() {
	# Part 1: CONFIG — distill's variables are expanded here, producing user values.
	cat <<HEADER
#!/bin/sh
# Generated by distill v${VERSION} — https://github.com/milvasic/distill

set -eu

# ══════════════════════════════════════════════════════════════════════════════
# CONFIG — edit this block or regenerate with:
#   distill --name "${binary_name}" \\
#     --asset-url "${asset_url}" \\
#     --installer-url "${installer_url}"
# ══════════════════════════════════════════════════════════════════════════════

BINARY_NAME="${binary_name}"
INSTALL_DIR="${install_dir}"
ASSET_TYPE="${asset_type}"
ASSET_URL="${asset_url}"
INSTALLER_URL="${installer_url}"
HEADER

	if [ "${asset_type}" = "binary" ]; then
		printf 'VERSION_URL="%s"\n' "${version_url}"
	else
		printf '# VERSION_URL=""  # only needed for ASSET_TYPE=binary\n'
	fi

	# Part 2: ENGINE — single-quoted heredoc; nothing below is expanded by distill.
	cat <<'ENGINE'

# ══════════════════════════════════════════════════════════════════════════════
# ENGINE — do not edit below this line
# ══════════════════════════════════════════════════════════════════════════════

INSTALL_PATH="${INSTALL_DIR}/${BINARY_NAME}"

# ── Colors & logging ──────────────────────────────────────────────────────────
RED="\033[0;31m"
GREEN="\033[0;32m"
BOLD="\033[1m"
RESET="\033[0m"

log() { printf "\n${BOLD}=== %s ===${RESET}\n" "$1"; }
error() { printf "${RED}ERROR:${RESET} %s\n" "$1" >&2; }
ok() { printf "${GREEN}%s${RESET}\n" "$1"; }

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
${BINARY_NAME} installer — install, update, or uninstall ${BINARY_NAME}.

Usage:
  install.sh [options]

Options:
  --uninstall   Remove ${BINARY_NAME} from ${INSTALL_DIR}
  --yes, -y     Auto-approve upgrade (useful for non-interactive / CI)
  --help        Show this message

Examples:
  # Install or update interactively
  sh -c "\$(curl -fsSL ${INSTALLER_URL})"

  # Install or update non-interactively
  sh -c "\$(curl -fsSL ${INSTALLER_URL})" -- --yes

  # Uninstall
  sh -c "\$(curl -fsSL ${INSTALLER_URL})" -- --uninstall
EOF
  exit 1
}

# ── Helpers ───────────────────────────────────────────────────────────────────

# Returns 0 if sudo is needed to write to INSTALL_DIR.
need_sudo() {
  ! [ -w "$INSTALL_DIR" ]
}

# Run a command, prepending sudo only if required.
run_cmd() {
  if need_sudo; then
    sudo "$@"
  else
    "$@"
  fi
}

# Fetch a URL, writing content to stdout.
fetch_url() {
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$1"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "$1"
  else
    error "Neither curl nor wget found. Please install one and try again."
    exit 1
  fi
}

# Download the asset to a temp file; sets TMPFILE.
# Optional argument: version string — substituted for {VERSION} in ASSET_URL.
download_asset() {
  TMPFILE="$(mktemp)"
  local url
  url="$(echo "$ASSET_URL" | sed "s/{VERSION}/${1:-}/g")"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$TMPFILE"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$TMPFILE" "$url"
  else
    error "Neither curl nor wget found. Please install one and try again."
    exit 1
  fi
}

# Extract VERSION="x.y.z" from a shell script file.
extract_version_script() {
  grep -m1 '^VERSION=' "$1" | sed 's/^VERSION="//;s/"$//'
}

# Get the remote (latest) version.
#   script: grepped from the downloaded asset (TMPFILE must already exist)
#   binary: fetched as plain text from VERSION_URL
get_remote_version() {
  case "$ASSET_TYPE" in
    script)
      extract_version_script "$TMPFILE"
      ;;
    binary)
      if [ -z "${VERSION_URL:-}" ]; then
        error "VERSION_URL must be set when ASSET_TYPE=binary."
        exit 1
      fi
      fetch_url "$VERSION_URL"
      ;;
  esac
}

# Get the version of the currently installed binary.
#   script: grepped from the installed file
#   binary: parsed from  binary --version  output (first x.y.z found)
get_installed_version() {
  case "$ASSET_TYPE" in
    script)
      extract_version_script "$INSTALL_PATH"
      ;;
    binary)
      "$INSTALL_PATH" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1
      ;;
  esac
}

# Compare two semver strings (X.Y.Z). Prints: greater | lesser | equal.
version_compare() {
  local v1="$1" v2="$2"

  if [ "$v1" = "$v2" ]; then
    echo "equal"
    return
  fi

  local i n1 n2
  for i in 1 2 3; do
    n1="$(echo "$v1" | cut -d. -f"$i")"
    n2="$(echo "$v2" | cut -d. -f"$i")"
    n1="${n1:-0}"
    n2="${n2:-0}"
    if [ "$n1" -gt "$n2" ]; then
      echo "greater"
      return
    elif [ "$n1" -lt "$n2" ]; then
      echo "lesser"
      return
    fi
  done

  echo "equal"
}

# ── Install / Update ──────────────────────────────────────────────────────────
do_install() {
  log "${BINARY_NAME} installer"

  # Sequencing differs by type: scripts are downloaded first (version is inside
  # the file); binaries need the version upfront to build the download URL.
  local remote_version
  case "$ASSET_TYPE" in
    script)
      download_asset
      trap 'rm -f "$TMPFILE"' EXIT
      remote_version="$(get_remote_version)"
      ;;
    binary)
      remote_version="$(get_remote_version)"
      download_asset "$remote_version"
      trap 'rm -f "$TMPFILE"' EXIT
      ;;
  esac

  if [ -z "$remote_version" ]; then
    error "Could not determine version from remote."
    exit 1
  fi

  # ── Fresh install ──────────────────────────────────────────────────────
  if [ ! -f "$INSTALL_PATH" ]; then
    run_cmd install -m 755 "$TMPFILE" "$INSTALL_PATH"
    ok "${BINARY_NAME} v${remote_version} installed to ${INSTALL_PATH}"
    return
  fi

  # ── Already installed — compare versions ───────────────────────────────
  local installed_version
  installed_version="$(get_installed_version)"

  if [ -z "$installed_version" ]; then
    error "Could not determine version of installed ${BINARY_NAME} at ${INSTALL_PATH}."
    exit 1
  fi

  local cmp
  cmp="$(version_compare "$remote_version" "$installed_version")"

  case "$cmp" in
    equal)
      ok "${BINARY_NAME} v${installed_version} is already installed and up to date."
      ;;
    greater)
      if [ "$auto_yes" = true ]; then
        run_cmd install -m 755 "$TMPFILE" "$INSTALL_PATH"
        ok "${BINARY_NAME} updated from v${installed_version} to v${remote_version}."
      elif [ -t 0 ]; then
        printf "Update %s from ${BOLD}v%s${RESET} to ${BOLD}v%s${RESET}? [y/N] " \
          "$BINARY_NAME" "$installed_version" "$remote_version"
        read -r reply
        case "$reply" in
          [Yy] | [Yy][Ee][Ss])
            run_cmd install -m 755 "$TMPFILE" "$INSTALL_PATH"
            ok "${BINARY_NAME} updated from v${installed_version} to v${remote_version}."
            ;;
          *)
            echo "Update cancelled."
            ;;
        esac
      else
        error "A newer version (v${remote_version}) is available (installed: v${installed_version})."
        error "Run interactively or pass --yes to auto-approve the update."
        exit 1
      fi
      ;;
    lesser)
      error "Installed version (v${installed_version}) is newer than remote (v${remote_version}). Aborting."
      exit 1
      ;;
  esac
}

# ── Uninstall ─────────────────────────────────────────────────────────────────
do_uninstall() {
  log "${BINARY_NAME} uninstaller"

  if [ ! -f "$INSTALL_PATH" ]; then
    echo "${BINARY_NAME} is not installed at ${INSTALL_PATH}. Nothing to do."
    return
  fi

  run_cmd rm -f "$INSTALL_PATH"
  ok "${BINARY_NAME} removed from ${INSTALL_PATH}."

  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/${BINARY_NAME}"
  if [ -d "$config_dir" ]; then
    local remove_config=false

    if [ "$auto_yes" = true ]; then
      remove_config=true
    elif [ -t 0 ]; then
      printf "Remove configuration directory at ${BOLD}%s${RESET}? [y/N] " "$config_dir"
      read -r reply
      case "$reply" in
        [Yy] | [Yy][Ee][Ss])
          remove_config=true
          ;;
      esac
    else
      error "Configuration directory exists at ${config_dir}"
      error "Run interactively or pass --yes to auto-remove it."
    fi

    if [ "$remove_config" = true ]; then
      rm -rf "$config_dir"
      ok "Configuration directory removed: ${config_dir}"
    fi
  fi
}

# ── Argument parsing & dispatch ───────────────────────────────────────────────
action="install"
auto_yes=false

for arg in "$@"; do
	case "$arg" in
	--uninstall) action="uninstall" ;;
	--yes | -y) auto_yes=true ;;
	--help | -h) usage ;;
	*)
		error "Unknown option: $arg"
		usage
		;;
	esac
done

case "$action" in
install) do_install ;;
uninstall) do_uninstall ;;
esac
ENGINE
}

# ── Argument parsing ──────────────────────────────────────────────────────────
binary_name=""
install_dir="/usr/local/bin"
asset_type="script"
asset_url=""
installer_url=""
version_url=""
output_file=""

# Track which optional-with-defaults flags were explicitly supplied
install_dir_set=false
asset_type_set=false

while [ $# -gt 0 ]; do
	case "$1" in
	--name)
		binary_name="${2:?--name requires an argument}"
		shift 2
		;;
	--install-dir)
		install_dir="${2:?--install-dir requires an argument}"
		install_dir_set=true
		shift 2
		;;
	--asset-type)
		asset_type="${2:?--asset-type requires an argument}"
		asset_type_set=true
		shift 2
		;;
	--asset-url)
		asset_url="${2:?--asset-url requires an argument}"
		shift 2
		;;
	--installer-url)
		installer_url="${2:?--installer-url requires an argument}"
		shift 2
		;;
	--version-url)
		version_url="${2:?--version-url requires an argument}"
		shift 2
		;;
	--output)
		output_file="${2:?--output requires an argument}"
		shift 2
		;;
	--version)
		echo "distill v${VERSION}"
		exit 0
		;;
	--help | -h) usage ;;
	*)
		error "Unknown option: $1"
		usage
		;;
	esac
done

# ── Interactive prompts for missing values ────────────────────────────────────
# Require both stdin AND stdout to be TTYs: if stdout is piped, the generated
# script is being consumed directly and prompts would corrupt the output.
if [ -t 0 ] && [ -t 1 ]; then
	log "distill v${VERSION}"
	printf "Press Enter to accept the value shown in [brackets].\n\n" >&2

	[ -z "$binary_name" ] && prompt binary_name "Binary name"
	[ -z "$asset_url" ] && prompt asset_url "Asset URL"
	[ -z "$installer_url" ] && prompt installer_url "Installer URL"
	[ "$install_dir_set" = false ] && prompt install_dir "Install directory" "$install_dir"

	if [ "$asset_type_set" = false ]; then
		_at=""
		prompt _at "Asset type (script/binary)" "$asset_type"
		asset_type="${_at:-$asset_type}"
	fi

	if [ "$asset_type" = "binary" ] && [ -z "$version_url" ]; then
		prompt version_url "Version URL"
	fi
fi

# ── Validate ──────────────────────────────────────────────────────────────────
_valid=true
[ -z "$binary_name" ] && {
	error "--name is required"
	_valid=false
}
[ -z "$asset_url" ] && {
	error "--asset-url is required"
	_valid=false
}
[ -z "$installer_url" ] && {
	error "--installer-url is required"
	_valid=false
}

case "$asset_type" in
script | binary) ;;
*)
	error "Invalid --asset-type '${asset_type}': must be 'script' or 'binary'"
	_valid=false
	;;
esac

if [ "$asset_type" = "binary" ] && [ -z "$version_url" ]; then
	error "--version-url is required for --asset-type binary"
	_valid=false
fi

[ "$_valid" = false ] && {
	echo >&2
	usage
}

# ── Generate ──────────────────────────────────────────────────────────────────
if [ -n "$output_file" ]; then
	generate_install_sh >"$output_file"
	chmod +x "$output_file"
	ok "Generated: ${output_file}"
else
	generate_install_sh
fi
